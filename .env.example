# Copy to .env ON THE AUTODL INSTANCE and fill in the real key.
# .env is gitignored AND rsync-excluded — the key must NEVER land in the synced data disk.
# Scripts run on the AutoDL instance (has internet); the local Mac does not need this file.
#
# Provider: Vultr Serverless Inference — OpenAI-compatible, ONE endpoint, ONE key, many models.
#   Models list: https://api.vultrinference.com/v1/chat/models

LLM_API_KEY=your-vultr-api-key-here
LLM_BASE_URL=https://api.vultrinference.com/v1

# ---- Model roles (all share LLM_API_KEY) ----
GEN_MODEL=DeepSeek-V4-Flash                          # drafts caption/QA from injected GT facts (text-only)
CHECK_MODEL=DeepSeek-V4-Flash                        # cross-check. MUST be a non-thinking model (clean JSON).
#   Avoid reasoning models here (e.g. Kimi-K2.6) — they emit thinking prose, not JSON, and fail parsing.
SAFETY_MODEL=Llama-3.1-Nemotron-Safety-Guard-8B-v3   # near-free forbidden-label scan (optional third gate)

# ---- Optional VISION stage — only the Omni model is multimodal; keep OFF for the SVIRO pilot ----
VISION_ENABLED=0
VISION_MODEL=Nemotron-3-Nano-Omni-30B-A3B-Reasoning-BF16
